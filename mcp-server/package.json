{
  "name": "roundtable-mcp",
  "version": "0.6.1",
  "description": "MCP server for multi-persona roundtable discussions",
  "main": "dist/index.js",
  "bin": {
    "roundtable-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --minify --outfile=dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=cjs --minify --outfile=dist/index.js --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "glob": "^11.0.2",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
